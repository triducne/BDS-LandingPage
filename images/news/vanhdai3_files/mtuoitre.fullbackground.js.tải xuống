function loadGPT(callback) {
    window.googletag = window.googletag || {};
    window.googletag.cmd = window.googletag.cmd || [];

    // Nếu GPT đã load rồi
    if (window.googletag.apiReady) {
        console.log("GPT already loaded");
        callback();
        return;
    }

    // Nếu script đang được load rồi thì không append thêm lần nữa
    if (document.querySelector('script[src*="securepubads.g.doubleclick.net/tag/js/gpt.js"]')) {
        console.log("GPT script already exists, waiting...");

        waitForGPT(callback);
        return;
    }

    var gptScript = document.createElement("script");
    gptScript.async = true;
    gptScript.src = "https://securepubads.g.doubleclick.net/tag/js/gpt.js";
    gptScript.crossOrigin = "anonymous";

    gptScript.onload = function () {
        console.log("GPT script loaded");
        waitForGPT(callback);
    };

    gptScript.onerror = function (e) {
        console.error("GPT script failed to load", e);

        BSDRequestPassback(
            document.querySelector("#div-gpt-ad-1739170112744696-0") || document.body,
            window.location.hostname
        );
    };

    document.head.appendChild(gptScript);
}


function waitForGPT(callback) {
    var retry = 0;
    var maxRetry = 50;

    var timer = setInterval(function () {
        retry++;

        if (window.googletag && window.googletag.apiReady) {
            clearInterval(timer);
            console.log("GPT apiReady");
            callback();
            return;
        }

        if (retry >= maxRetry) {
            clearInterval(timer);
            console.error("GPT apiReady timeout");

            BSDRequestPassback(
                document.querySelector("#div-gpt-ad-1739170112744696-0") || document.body,
                window.location.hostname
            );
        }
    }, 100);
}