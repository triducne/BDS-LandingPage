function identifyLinkType(url, html = "") {
  const homeRegex = /^https:\/\/[^\/]+\/?(?:[?#].*)?$/;

  const postRegex =
    /^https:\/\/[^\/]+\/([^\/]+\/)*[\w-]+-\d{12,}\.htm(?:[?#].*)?$/;

  const categoryRegex =
    /^https:\/\/[^\/]+\/(tag\/)?[^\/]+\/?(?:[?#].*)?$/;

  if (homeRegex.test(url)) {
    return "home";
  } else if (postRegex.test(url)) {
    return "article";
  } else if (
    categoryRegex.test(url) &&
    html.includes('class="list__breadcrumb-flex"')
  ) {
    return "category";
  } else {
    return "unknown";
  }
}

function getTrimmedSlug(url) {
  const path = new URL(url).pathname;
  const slug = path.split('/').pop().replace('.html', '');
  const parts = slug.split('-');
  const trimmedSlug = parts.slice(0, parts.length - 1).join('-');
  return trimmedSlug;
}

